# =============================================================================
# Component selection (optional). Each value picks one entry from main.py's
# registries; defaults shown. Available choices are listed in README.md.
# =============================================================================
# SIGNUP_REGISTRAR=deepseek
# SIGNUP_CHECKCODE=qq_mail
# SIGNUP_ACCOUNT_GENERATOR=duck_email

# =============================================================================
# Per-component secrets / settings (only the ones used by your selection above
# need to be filled in).
# =============================================================================

# [registrar=deepseek] 数美设备指纹（base64 串）。浏览器打开 https://chat.deepseek.com，
# 控制台执行 `await window.SMSdk?.getDeviceId?.()`，整串复制过来。
DEEPSEEK_DEVICE_ID="<paste-base64-device-id>"

# [registrar=deepseek] 给每个新注册账号统一设置的密码。
DEEPSEEK_REGISTER_PASSWORD="<choose-a-strong-password>"

# [checkcode=qq_mail] QQ 邮箱整段 Cookie。浏览器登录 https://wx.mail.qq.com，
# F12 -> Network -> 任选 /list/maillist -> Copy as cURL，复制 Cookie: 后的整串。
# 必须包含 xm_sid（或 sid）、xm_skey、xm_data_ticket。
QQ_MAIL_COOKIE="pac_uid=...; sid=...; xm_sid=...; xm_skey=...; xm_data_ticket=..."

# [account_generator=duck_email] DuckDuckGo Email Protection Bearer Token。
# 从已登录的 Duck 浏览器扩展存储里取，或参考 gen-spider-out/duckduckgo-email-autofill
# 的抓包方式。
DUCK_EMAIL_API_TOKEN="<paste-duck-bearer-token>"
